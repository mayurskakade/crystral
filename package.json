{
  "name": "crystalai-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first AI agent framework for developers",
  "scripts": {
    "build": "pnpm -r build",
    "build:core": "pnpm --filter @crystalai/core build",
    "build:cli": "pnpm --filter @crystalai/cli build",
    "build:sdk": "pnpm --filter @crystalai/sdk build",
    "build:studio": "pnpm --filter @crystalai/studio build",
    "dev": "pnpm --filter @crystalai/core dev",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "clean": "pnpm -r clean",
    "typecheck": "pnpm -r typecheck"
  },
  "keywords": [
    "ai",
    "agent",
    "llm",
    "openai",
    "anthropic",
    "rag",
    "local-first"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}
