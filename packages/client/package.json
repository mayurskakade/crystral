{
  "name": "@crystralai/client",
  "version": "0.1.0",
  "description": "Universal client-side SDK for Crystral — browser, React Native, Electron, Edge. Zero Node.js dependencies.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --config vitest.config.ts",
    "clean": "rm -rf dist",
    "prepack": "cp ../../LICENSE ./LICENSE"
  },
  "keywords": [
    "ai",
    "agent",
    "llm",
    "browser",
    "react-native",
    "electron",
    "client",
    "byok",
    "openai",
    "anthropic",
    "groq",
    "google",
    "together"
  ],
  "author": "Mayur Kakade <mskakade111@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mayurskakade/crystral.git",
    "directory": "packages/client"
  },
  "bugs": {
    "url": "https://github.com/mayurskakade/crystral/issues"
  },
  "homepage": "https://github.com/mayurskakade/crystral#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.8.2",
    "vitest": "^2.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
