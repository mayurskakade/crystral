{
  "name": "@crystralai/core",
  "version": "0.4.1",
  "description": "Core runtime engine for Crystral - providers, storage, agent runner, RAG, tools",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "clean": "rm -rf dist *.tsbuildinfo",
    "prepack": "cp ../../LICENSE ./LICENSE"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "dotenv": "^16.4.0",
    "js-yaml": "^4.1.0",
    "uuid": "^10.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.14.0",
    "@types/uuid": "^10.0.0",
    "tsup": "^8.1.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "keywords": [
    "ai",
    "agent",
    "llm",
    "rag",
    "local-first"
  ],
  "author": "Mayur Kakade <mskakade111@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mayurskakade/crystral.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/mayurskakade/crystral/issues"
  },
  "homepage": "https://github.com/mayurskakade/crystral#readme",
  "publishConfig": {
    "access": "public"
  }
}
