{
  "name": "@crystralai/sdk",
  "version": "0.4.0",
  "description": "TypeScript SDK for Crystral - Local-first AI agent framework",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepack": "cp ../../LICENSE ./LICENSE",
    "docs": "typedoc",
    "docs:watch": "typedoc --watch"
  },
  "keywords": [
    "ai",
    "agent",
    "llm",
    "local",
    "framework",
    "sdk"
  ],
  "author": "Mayur Kakade <mskakade111@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mayurskakade/crystral.git",
    "directory": "packages/sdk"
  },
  "bugs": {
    "url": "https://github.com/mayurskakade/crystral/issues"
  },
  "homepage": "https://github.com/mayurskakade/crystral#readme",
  "dependencies": {
    "@crystralai/core": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typedoc": "^0.27.0",
    "typedoc-plugin-markdown": "^4.4.0",
    "typescript": "^5.8.2"
  },
  "peerDependencies": {
    "typescript": ">=5.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
