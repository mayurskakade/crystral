{
  "name": "@crystral/studio",
  "version": "0.5.0",
  "description": "Local development dashboard for Crystral - visual agent interaction, session browsing, and log viewing",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "ai",
    "agent",
    "llm",
    "studio",
    "dashboard",
    "local-first"
  ],
  "author": "dnyantra",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dnyantra/crystral.git",
    "directory": "packages/studio"
  },
  "bugs": {
    "url": "https://github.com/dnyantra/crystral/issues"
  },
  "homepage": "https://github.com/dnyantra/crystral#readme",
  "dependencies": {
    "@crystral/core": "workspace:*",
    "@hono/node-server": "^1.14.0",
    "hono": "^4.7.0",
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.14.0",
    "tsup": "^8.5.1",
    "typescript": "^5.8.2"
  }
}
